аторных исследований и анализов.","heroImageUrl":"","body":"","metaTitle":"Лабораторные анализы — ММЦ МЕДЕО","metaDescription":"Широкий спектр лабораторных исследований и анализов.","kind":"specialty","priceCategoryId":"42953a79-c47c-4a5e-ad50-2dbe53bd8154","services":[]},{"id":"15a66774-d590-413f-a7fb-aeb5f04449b9","slug":"massazh-i-manualnaya-terapiya","label":"Массаж и мануальная терапия","description":"Лечебный массаж и мануальная терапия","stat":"","statLabel":"","imageUrl":"","sortOrder":11,"active":true,"accent":"#9d174d","heroTitle":"Массаж и мануальная терапия","intro":"Лечебный массаж и мануальная терапия для здоровья спины и суставов.","heroImageUrl":"","body":"","metaTitle":"Массаж и мануальная терапия — ММЦ МЕДЕО","metaDescription":"Лечебный массаж и мануальная терапия для здоровья спины и суставов.","kind":"specialty","priceCategoryId":"d7375271-a9c0-46d5-a336-a814663a23e3","services":[]},{"id":"82c4e8d1-42bb-47a8-80fd-44f1f41c50fd","slug":"procedurnyy-kabinet","label":"Процедурный кабинет","description":"Инъекции, капельницы, манипуляции","stat":"","statLabel":"","imageUrl":"","sortOrder":12,"active":true,"accent":"#155e75","heroTitle":"Процедурный кабинет","intro":"Инъекции, капельницы и медицинские манипуляции.","heroImageUrl":"","body":"","metaTitle":"Процедурный кабинет — ММЦ МЕДЕО","metaDescription":"Инъекции, капельницы и медицинские манипуляции.","kind":"specialty","priceCategoryId":"f30e189f-5e2c-481b-8958-03150c93b4d1","services":[]},{"id":"d7ff7066-111a-4468-b42e-9fe7bac6c9b4","slug":"spravki-i-dokumenty","label":"Справки и документы","description":"Оформление медицинских справок","stat":"","statLabel":"","imageUrl":"","sortOrder":13,"active":true,"accent":"#374151","heroTitle":"Медицинские справки и документы","intro":"Оформление медицинских справок и документов.","heroImageUrl":"","body":"","metaTitle":"Справки и документы — ММЦ МЕДЕО","metaDescription":"Оформление медицинских справок и документов.","kind":"specialty","priceCategoryId":"0a